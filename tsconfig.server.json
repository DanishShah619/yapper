{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "declaration": false,
    "incremental": false,
    "isolatedModules": false,
    "module": "CommonJS",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "dist/server",
    "rootDir": ".",
    "sourceMap": false,
    "types": ["node"]
  },
  "include": [
    "server.ts",
    "lib/**/*.ts",
    "graphql/context.ts",
    "workers/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
